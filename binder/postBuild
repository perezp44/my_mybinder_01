#!/bin/bash

# --- 1. Instalación de Quarto (SIN SUDO) ---
# Binder ya suele traer Quarto, pero si necesitas una versión específica:
# Descargamos y extraemos en una carpeta donde TENGAMOS permiso (nuestro home)
curl -LO https://github.com/quarto-dev/quarto-cli/releases/download/v1.4.550/quarto-1.4.550-linux-amd64.tar.gz
mkdir -p ~/quarto
tar -xzf quarto-1.4.550-linux-amd64.tar.gz -C ~/quarto --strip-components=1
# Añadimos Quarto al PATH para que RStudio lo encuentre
export PATH=$PATH:~/quarto/bin
rm quarto-1.4.550-linux-amd64.tar.gz

# --- 2. Configuración de RStudio ---
# Primero creamos la carpeta con -p (por si acaso)
mkdir -p /home/jovyan/.config/rstudio/

# Copiamos el archivo (asegúrate de que rstudio-prefs.json esté en la raíz del repo)
cp rstudio-prefs.json /home/jovyan/.config/rstudio/rstudio-prefs.json

